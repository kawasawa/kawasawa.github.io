# NOTE: 可能であればパッケージバージョンは固定したい
# - パッケージ管理ファイル
#     package.json: プロダクトが依存するパッケージの要件を定義
#     yarn.lock: 実際にインストールされたパッケージの正確なバージョンと依存関係を定義
# - バージョン表記
#     ^1.2.3: 1.2.3 以上 2.0.0 未満
#     ~1.2.3: 1.2.3 以上 1.3.0 未満
#      1.2.*: 1.2.0 以上 1.3.0 未満 (1.2.x と同義)
#      1.2.3: 1.2.3 のみ
# - 既定の動作
#     npm と Yarn はデフォルトで ^ が指定される。
#     これにより major バージョンを固定しつつ、minor バージョン以降の更新が許可される。
#     パッケージがセマンティックバージョニング (minor バージョンの更新は互換性を維持する) に則るのであれば有効だが、
#     実際はすべてのパッケージがこれを厳守しているわけではなく、破壊的な変更を含む場合もあり少々危険である。
#
#save-prefix: ""

# タイムアウト時間を延長する
network-timeout: 600000
